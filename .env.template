# --- ROS 2 Environment ---
ROS_DOMAIN_ID=

# API Orchestrator (DeepSeek via Proxy)
ORCHESTRATOR_API_KEY="injected_by_gateway_proxy"
ORCHESTRATOR_API_URL="http://api-gateway:8080/v1"
ORCHESTRATOR_MODEL_CHAT="deepseek-v4-flash"
ORCHESTRATOR_MODEL_REASONER="deepseek-reasoner"

# Specialist Services
ORCHESTRATOR_REJECT_IF_BUSY=true
ORCHESTRATOR_ENABLE_QUEUING=false
ORCHESTRATOR_REJECT_MSG="Eva is currently busy. Please wait a moment."
RESEARCHER_API_URL="http://eva-researcher-vision:8080/v1"

# Memory Layer (Qdrant)
QDRANT_HTTP_API="http://eva-qdrant:6333"
QDRANT_GRPC_API="http://eva-qdrant:6334"

# Search Service (SearXNG via Gateway)
MASTER_SEARXNG_URL="http://api-gateway:8080/search"
MASTER_SEARXNG_LANGUAGE="en-US"

# Visual / TTI Subsystem
TTI_MODEL_TYPE="sdxl_turbo"
TTI_MODELS_PATH="/models"
TTI_CPU_OFFLOAD="false"
TTI_OUTPUT_PATH="/tmp/eva_artist.jpg"
