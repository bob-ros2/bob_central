server {
    listen 8080;

    # Streaming and Timeout optimizations for slow inference
    proxy_buffering off;
    proxy_cache off;
    proxy_set_header Connection "";
    proxy_http_version 1.1;
    chunked_transfer_encoding on;
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
    keepalive_timeout 600s;

    location /v1/ {
        # Streaming Security: Disable ALL buffering layers
        proxy_buffering off;
        proxy_cache off;
        proxy_set_header X-Accel-Buffering no;
        gzip off;

        # Inject the API Key from the environment variable (if needed)
        proxy_set_header Authorization "Bearer ${ORCHESTRATOR_API_KEY}";
        proxy_set_header Content-Type "application/json";
        
        # Forward to the backend (DeepSeek OR local Qwen via env)
        proxy_pass https://api.deepseek.com/v1/;
        
        # Handle SSL for remote backends
        proxy_ssl_server_name on;
        proxy_ssl_protocols TLSv1.2 TLSv1.3;
        
        # Preserve error messages from upstream
        proxy_intercept_errors off;
    }

    # Proxy SearXNG search requests
    location /search {
        proxy_pass http://192.168.1.10:9080/search;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
