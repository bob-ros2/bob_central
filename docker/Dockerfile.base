# -- Eva Core Intelligence (The Brain Container) --
ARG ROS_DISTRO=humble
FROM ros:${ROS_DISTRO}-ros-base

ENV DEBIAN_FRONTEND=noninteractive
ENV SHELL=/bin/bash

# -- Install System Dependencies --
RUN apt-get update && apt-get install -y \
    vim \
    build-essential \
    ffmpeg \
    jq \
    htop \
    python3-pip \
    python3-colcon-common-extensions \
    ros-${ROS_DISTRO}-cv-bridge \
    ros-${ROS_DISTRO}-sensor-msgs \
    git \
    curl \
    wget \
    iputils-ping \
    dnsutils \
    netcat-openbsd \
    cron \
    procps \
    psmisc \
    openssh-client \
    && rm -rf /var/lib/apt/lists/* \
    && git config --global --add safe.directory '*'

# -- Install NVIDIA Utilities (nvidia-smi) --
# Default version for nvidia-utils (can be overridden via build-arg)
ARG NVIDIA_VERSION=535
RUN apt-get update && apt-get install -y --no-install-recommends \
    nvidia-utils-${NVIDIA_VERSION}-server \
    && rm -rf /var/lib/apt/lists/*

# -- Install Python Dependencies for Eva --
# Leverage Docker layer caching for requirements
COPY requirements.txt /tmp/requirements.txt
RUN pip3 install --no-cache-dir -r /tmp/requirements.txt

# -- ROS 2 Workspace Setup --
# Context must be set to repo root (..) in compose file
WORKDIR /ros2_ws
RUN mkdir -p /ros2_ws/src

# 1. Clone Bob's engine dependencies & install their requirements
RUN git clone https://github.com/bob-ros2/bob_llm /ros2_ws/src/bob_llm && \
    if [ -f /ros2_ws/src/bob_llm/requirements.txt ]; then pip3 install --no-cache-dir -r /ros2_ws/src/bob_llm/requirements.txt; fi

RUN git clone https://github.com/bob-ros2/bob_launch /ros2_ws/src/bob_launch && \
    if [ -f /ros2_ws/src/bob_launch/requirements.txt ]; then pip3 install --no-cache-dir -r /ros2_ws/src/bob_launch/requirements.txt; fi

# -- Build the Workspace --
ARG CACHE_BUST=1
# 2. Copy current local repo (bob_central) into workspace
COPY . /ros2_ws/src/bob_central

RUN . /opt/ros/${ROS_DISTRO}/setup.sh && \
    colcon build --symlink-install --packages-select bob_llm bob_central bob_launch

# -- Entrypoint Script --
RUN echo "#!/bin/bash\nservice cron start\nsource /opt/ros/\${ROS_DISTRO}/setup.bash\nsource /ros2_ws/install/setup.bash\nexec \"\$@\"" > /ros_entrypoint.sh \
    && chmod +x /ros_entrypoint.sh

ENTRYPOINT ["/ros_entrypoint.sh"]

# Launch the orchestrator by default 
CMD ["ros2", "launch", "bob_launch", "generic.launch.py", "config:=/ros2_ws/src/bob_central/launch/orch_smart_ai.yaml"]