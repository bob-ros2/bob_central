server {
    listen 8080;

    # Global Streaming optimizations
    tcp_nodelay on;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_cache off;
    proxy_set_header Connection "";
    proxy_http_version 1.1;
    chunked_transfer_encoding on;
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
    keepalive_timeout 600s;

    location /v1/ {
        # Security & Speed: Disable ALL buffering layers
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        proxy_set_header X-Accel-Buffering no;
        proxy_ignore_headers "Expires" "Cache-Control" "Set-Cookie";
        gzip off;

        # Inject the API Key from the environment variable (if needed)
        proxy_set_header Authorization "Bearer ${UPSTREAM_API_KEY}";
        proxy_set_header Content-Type "application/json";
        
        # Forward to the backend (DeepSeek OR local)
        proxy_pass ${UPSTREAM_API_URL};
        
        # Handle SSL for remote backends
        proxy_ssl_server_name on;
        proxy_ssl_protocols TLSv1.2 TLSv1.3;
        
        # Preserve error messages from upstream
        proxy_intercept_errors off;
    }

    # Proxy SearXNG search requests
    location /search {
        proxy_pass ${MASTER_SEARXNG_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # CouchDB Proxy (Explicit path)
    location /couchdb/ {
        proxy_pass http://192.168.1.10:5984/;
        proxy_set_header Authorization "${COUCHDB_AUTH_BASIC}";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
